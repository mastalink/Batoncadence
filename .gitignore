.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.fullname
.pytest_cache/
.pytest_cache/

# Translations
*.mo
*.pot

# Django stuff:
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Sphinx documentation
docs/_build/

# PyBuilder
.pybuilder/
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
#   For a library or package, you might want to ignore these files since the values are
#   specific to the developer's machine and not the project itself.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if used in a top-level app, it should be committed,
#   but in a library/package, it should be ignored.
# Pipfile.lock

# poetry
#   Similar to Pipfile.lock, it is personal preference to ignore or keep poetry.lock
#   in version control.
# poetry.lock

# pdm
#   Similar to Pipfile.lock, it is personal preference to ignore or keep pdm.lock
#   in version control.
# pdm.lock

# virtualenv
.venv/
venv/
ENV/
env/
#   For standard python packages, standard environments:
Virtualenvs/

# PEP 582; incoming dependency management concept
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

# Environments
.env
.env.local
.env.development
.env.test
.env.production
.env.staging

# Secrets / Encryption local artifacts
secrets.enc
.mco/

# IDEs
.idea/
.vscode/
*.swp
*.swo
configs/_filled/

# wrangler deploy artifacts
.wrangler/

# Local session transcripts / scratch
*-this-session-is-being-continued-*.txt

# Air-gapped wheel cache (created by make-offline-bundle)
offline/

# Internal / business-only — never published
plans/
